<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceBlock name="checkout.root">
            <arguments>
                <argument name="jsLayout" xsi:type="array">
                    <item name="components" xsi:type="array">
                        <item name="checkout" xsi:type="array">
                            <item name="children" xsi:type="array">
                                <item name="steps" xsi:type="array">
                                    <item name="children" xsi:type="array">
                                        <item name="shipping-step" xsi:type="array">
                                            <item name="children" xsi:type="array">
                                                <item name="shippingAddress" xsi:type="array">
                                                    <item name="children" xsi:type="array">
                                                        <!--
                                                            Render in `before-shipping-method-form` (a real
                                                            displayArea inside the shipping form's container)
                                                            so the component is created in DOM, then JS
                                                            relocates it to sit directly under the vat_id
                                                            input. The address fieldset is built dynamically
                                                            from EAV attributes, so a static XML child of
                                                            shipping-address-fieldset would not survive — DOM
                                                            relocation is the reliable cross-theme approach.
                                                        -->
                                                        <item name="before-shipping-method-form" xsi:type="array">
                                                            <item name="children" xsi:type="array">
                                                                <item name="byte8-vat-validate" xsi:type="array">
                                                                    <item name="component" xsi:type="string">Byte8_VatValidator/js/view/vat-validate-button</item>
                                                                    <item name="displayArea" xsi:type="string">before-shipping-method-form</item>
                                                                    <item name="sortOrder" xsi:type="string">0</item>
                                                                    <item name="config" xsi:type="array">
                                                                        <item name="addressType" xsi:type="string">shipping</item>
                                                                    </item>
                                                                </item>
                                                            </item>
                                                        </item>
                                                    </item>
                                                </item>
                                            </item>
                                        </item>
                                    </item>
                                </item>
                            </item>
                        </item>
                    </item>
                </argument>
            </arguments>
        </referenceBlock>
    </body>
</page>
