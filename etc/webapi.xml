<routes xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Webapi:etc/webapi.xsd">

    <route url="/V1/byte8-vat-validator/validate/:countryCode/:vatNumber" method="GET">
        <service class="Byte8\VatValidator\Api\VatValidatorInterface" method="validate"/>
        <resources>
            <resource ref="anonymous"/>
        </resources>
    </route>
</routes>
